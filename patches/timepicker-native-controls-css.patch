+	/*
+	 * Native date/time inputs with a full-field click target.
+	 * Stretch the webkit picker indicator across the whole control so clicks
+	 * anywhere (including our decorative icon) open the browser picker.
+	 * Firefox already opens on field click; showPicker() is also wired in JS.
+	 */
+	.native-datetime {
+		/* Icon sits in pr-10 gutter; keep native control behavior intact */
+		color-scheme: light;
+	}
+
+	.dark .native-datetime {
+		color-scheme: dark;
+	}
+
+	.native-datetime::-webkit-calendar-picker-indicator {
+		position: absolute;
+		inset: 0;
+		width: 100%;
+		height: 100%;
+		margin: 0;
+		padding: 0;
+		cursor: pointer;
+		opacity: 0;
+	}
+
+	/* Some Chromium builds use a separate clear/spin UI — keep the field clickable */
+	.native-datetime::-webkit-clear-button,
+	.native-datetime::-webkit-inner-spin-button {
+		display: none;
+	}
+
